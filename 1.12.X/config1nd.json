        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL"
      ],
      "default": "JP-Auto"
    },
    {
      "tag": "Openai",
      "type": "selector",
      "outbounds": [
        "PROXY",
        "DIRECT",
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL"
      ],
      "default": "TW-Auto"
    },
    {
      "tag": "Github",
      "type": "selector",
      "outbounds": [
        "PROXY",
        "DIRECT",
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL"
      ],
      "default": "PROXY"
    },
    {
      "tag": "Steam",
      "type": "selector",
      "outbounds": [
        "PROXY",
        "DIRECT",
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL"
      ],
      "default": "PROXY"
    },
    {
      "tag": "PROXY",
      "type": "selector",
      "outbounds": [
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL",
        "DIRECT"
      ],
      "default": "ALL"
    },
    {
      "tag": "FINAL",
      "type": "selector",
      "outbounds": [
        "PROXY",
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL",
        "DIRECT"
      ],
      "default": "ALL"
    },
    {
      "tag": "ALL",
      "type": "selector",
      "use_all_providers": true
    },
    {
      "tag": "HK",
      "type": "selector",
      "use_all_providers": true,
      "include": "(?i)(🇭🇰|港|\\bhk\\b|\\bHK\\b|hongkong|hong kong|Hong Kong)"
    },
    {
      "tag": "TW",
      "type": "selector",
      "use_all_providers": true,
      "include": "(?i)(🇹🇼|台|\\btw\\b|\\bTW\\b|taiwan|Taiwan|taipei|台北)"
    },
    {
      "tag": "JP",
      "type": "selector",
      "use_all_providers": true,
      "include": "(?i)(🇯🇵|日|\\bjp\\b|\\bJP\\b|japan|Japan|东京)"
    },
    {
      "tag": "SG",
      "type": "selector",
      "use_all_providers": true,
      "include": "(?i)(🇸🇬|新|\\bsg\\b|\\bSG\\b|singapore|Singapore)"
    },
    {
      "tag": "US",
      "type": "selector",
      "use_all_providers": true,
      "include": "(?i)(🇺🇸|美|\\bUS\\b|\\bus\\b|unitedstates|united states|United States)"
    },
    {
      "tag": "HK-Auto",
      "type": "urltest",
      "use_all_providers": true,
//      "providers": [
//      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "150s",
      "include": "(?i)(🇭🇰|港|\\bhk\\b|\\bHK\\b|hongkong|hong kong|Hong Kong)",
      "tolerance": 30
    },
    {
      "tag": "TW-Auto",
      "type": "urltest",
      "use_all_providers": true,
      "url": "https://www.gstatic.com/generate_204",
      "interval": "150s",
      "include": "(?i)(🇹🇼|台|\\btw\\b|\\bTW\\b|taiwan|Taiwan|taipei|台北)",
      "tolerance": 30
    },
    {
      "tag": "JP-Auto",
      "type": "urltest",
      "use_all_providers": true,
      "url": "https://www.gstatic.com/generate_204",
      "interval": "150s",
      "include": "(?i)(🇯🇵|日|\\bjp\\b|\\bJP\\b|japan|Japan|东京)",
      "tolerance": 30
    },
    {
      "tag": "SG-Auto",
      "type": "urltest",
      "use_all_providers": true,
      "url": "https://www.gstatic.com/generate_204",
      "interval": "150s",
      "include": "(?i)(🇸🇬|新|\\bsg\\b|\\bSG\\b|singapore|Singapore)",
      "tolerance": 30
    },
    {
      "tag": "US-Auto",
      "type": "urltest",
      "use_all_providers": true,
      "url": "https://www.gstatic.com/generate_204",
      "interval": "150s",
      "include": "(?i)(🇺🇸|美|\\bUS\\b|\\bus\\b|unitedstates|united states|United States)",
      "tolerance": 30
    },
    {
      "tag": "GLOBAL",
      "type": "selector",
      "outbounds": [
        "DIRECT",
        "PROXY",
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL",
        "FINAL"
      ],
      "default": "DIRECT"
    },
    {
      "tag": "DIRECT",
      "type": "direct"
    }
  ],
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 7080
    },
//    {
//      "type": "direct",
//      "tag": "dns-in",
//      "listen": "::",
 //     "listen_port": 1053
