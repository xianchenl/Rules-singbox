    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "::",
      "listen_port": 1536
    }
  ],
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "dashboard",
      "external_ui_download_url": "https://ghfast.top/https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
      "external_ui_update_interval": "1d"
    },
    "cache_file": {
      "enabled": true,
      "path": "./cache.db",
      "store_fakeip": true
    }
  },
  "log": {
    "disabled": false,
    "level": "trace",
    "timestamp": true,
    "output": "./sing-box.log"
  }
