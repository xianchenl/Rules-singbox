        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/private.srs"
      },
      {
        "tag": "google_ip",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/google_ip.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/google.srs"
      },
      {
        "tag": "google_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/google.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/google.srs"
      },
      {
        "tag": "twitter_ip",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/twitter_ip.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/twitter.srs"
      },
      {
        "tag": "twitter_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/twitter.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/twitter.srs"
      },
      {
        "tag": "netflix_ip",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/netflix_ip.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/netflix.srs"
      },
      {
        "tag": "netflix_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/netflix.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/netflix.srs"
      },
      {
        "tag": "ai_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/ai.srs",
        "url": "https://ghfast.top/raw.githubusercontent.com/DustinWin/ruleset_geodata/refs/heads/sing-box-ruleset/ai.srs"
      },
      {
        "tag": "telegram_ip",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/telegram_ip.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/telegram.srs"
      },
      {
        "tag": "telegram_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/telegram.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/telegram.srs"
      },
      {
        "tag": "youtube_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/youtube.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/youtube.srs"
      },
      {
        "tag": "github_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/github.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/github.srs"
      },
      {
        "tag": "steam_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/steam.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/steam.srs"
      },
      {
        "tag": "no-ads",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/no-ads.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/privacy-protection-tools/anti-ad.github.io/master/docs/anti-ad-sing-box.srs"
      }
    ],
    "final": "FINAL",
    "find_process": true,
    "auto_detect_interface": true
  },
  "outbounds": [
    {
      "tag": "Google",
      "type": "selector",
      "outbounds": [
        "PROXY",
        "DIRECT",
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL"
      ],
      "default": "PROXY"
    },
    {
      "tag": "Telegram",
      "type": "selector",
      "outbounds": [
        "PROXY",
        "DIRECT",
        "HK",
        "TW",
        "JP",
        "SG",
        "US",
        "HK-Auto",
        "TW-Auto",
        "JP-Auto",
        "SG-Auto",
        "US-Auto",
        "ALL"
      ],
      "default": "SG-Auto"
    },
    {
