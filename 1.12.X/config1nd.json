{
  "http_clients": [
    {
      "tag": "Direct_download",
      "version": 2
    }
  ],
  "providers": [
    {
      "type": "remote",
      "tag": "Mitce",
      "url": "",
      "path": "./providers/Mitce.json",
      "health_check": {
        "enabled": true,
        "url": "https://www.gstatic.com/generate_204",
        "interval": "10m",
        "timeout": "30s"
      },
      "update_interval": "5h"
    },
    {
      "type": "remote",
      "tag": "快跑",
      "url": "",
      "path": "./providers/快跑.json",
      "health_check": {
        "enabled": true,
        "url": "https://www.gstatic.com/generate_204",
        "interval": "10m",
        "timeout": "30s"
      },
      "update_interval": "5h"
    }
  ],  
  "dns": {
    "servers": [
      {
        "tag":"tx",
        "type":"https",
        "server":"119.29.29.29", 
        "path": "/dns-query"
      },
      {
        "tag":"ali",
        "type":"https",
        "server":"223.5.5.5",
        "path": "/dns-query"
      },
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      },
      {
        "type": "group",
        "tag": "cndns",
        "servers": [
          "ali",
          "tx"
        ]
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "server": "ali"
      },
      {
        "clash_mode": "Global",
        "query_type": [
          "HTTPS",
          "SVCB"
        ],
        "action": "reject"
      },
      {
        "clash_mode": "Global",
        "server": "fakeip"
      },
      {
        "rule_set": "fakeip-filter",
        "server": "DIRECT"
      },
      {
        "query_type": [
          "HTTPS",
          "SVCB"
        ],
        "action": "reject"
      },
      {
        "action": "evaluate",
        "server": "cndns"
      },
      {
        "match_response": true,  
        "rule_set": ["cn_domain", "cn_ip"],
        "domain_regex": "(^|\\.)(alt[1-8]-mtalk|mtalk|mtalk4)\\.google\\.com$",
        "server": "cndns"
      },
      {
        "rule_set": "no-ads",
        "action": "reject"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "fakeip",
        "rewrite_ttl": 1
      }
    ],
    "final": "cndns",
    "strategy": "prefer_ipv4"
  },
  "route": {
    "default_domain_resolver": "cndns",
    "rules": [
      {
        "action": "sniff",
        "sniffer": [
          "http",
          "tls",
          "quic"
        ]
      },
      {
        "network": "udp",
        "port": 53,
        "action": "sniff",
        "sniffer": "dns"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "DIRECT"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "outbound": "GLOBAL"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "outbound": "DIRECT"
      },
      {
        "rule_set": "netflix_domain",
        "action": "route",
        "outbound": "Netflix"
      },
      {
        "rule_set": "youtube_domain",
        "action": "route",
        "outbound": "Youtube"
      },
      {
        "rule_set": "twitter_domain",
        "action": "route",
        "outbound": "Twitter"
      },
      {
        "rule_set": "ai_domain",
        "action": "route",
        "outbound": "Openai"
      },
      {
        "rule_set": "github_domain",
        "action": "route",
        "outbound": "Github"
      },
      {
        "rule_set": "steam_domain",
        "action": "route",
        "outbound": "Steam"
      },
      {
        "rule_set": "google_domain",
        "action": "route",
        "outbound": "Google"
      },
      {
        "rule_set": "telegram_domain",
        "action": "route",
        "outbound": "Telegram"
      },
      {
        "rule_set": "no-ads",
        "action": "reject"
      },
      {
        "rule_set": "cn_domain",
        "action": "route",
        "outbound": "DIRECT"
      },
      {
        "action": "resolve",
        "match_only": true
      },
      {
        "rule_set": "netflix_ip",
        "action": "route",
        "outbound": "Netflix"
      },
      {
        "rule_set": "twitter_ip",
        "action": "route",
        "outbound": "Twitter"
      },
      {
        "rule_set": "telegram_ip",
        "action": "route",
        "outbound": "Telegram"
      },
      {
        "rule_set": "google_ip",
        "action": "route",
        "outbound": "Google"
      },
      {
        "rule_set": "private_ip",
        "action": "route",
        "outbound": "DIRECT"
      },
      {
        "rule_set": "cn_ip",
        "action": "route",
        "outbound": "DIRECT"
      }
    ],
    "rule_set": [
      {
        "tag": "fakeip-filter",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/fakeip-filter.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/DustinWin/ruleset_geodata/refs/heads/sing-box-ruleset/fakeip-filter.srs"
      },
      {
        "tag": "cn_ip",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/cn_ip.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/cn.srs"
      },
      {
        "tag": "cn_domain",
        "type": "remote",
        "format": "binary",
        "path": "./rule_provider/cn.srs",
        "url": "https://ghfast.top/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/cn.srs"
      },
      {
